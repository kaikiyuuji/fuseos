APP_NAME=FuseOS
APP_ENV=testing
APP_KEY=base64:QFkqWaAKat4GmJNV7KzqqM93fclKFW+oMDDsj5xwIoU=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=single
LOG_LEVEL=warning

# SQLite in-memory para testes rápidos e isolados
DB_CONNECTION=sqlite
DB_DATABASE=:memory:

# Cache/Session/Queue como array (sem Redis real nos testes)
CACHE_STORE=array
SESSION_DRIVER=array
QUEUE_CONNECTION=sync

# Broadcasting desligado em testes (eventos não são disparados)
BROADCAST_CONNECTION=null

# Redis mockado (array driver, sem conexão real)
REDIS_CLIENT=array

# Spatie Permission — evita colisão de cache entre testes
PERMISSION_CACHE_EXPIRATION_TIME=-1
